# Rust
/target/
**/target/
Cargo.lock.bak
*.rs.bk

# IDE
.idea/
.vscode/
*.iml
*.swp
*.swo

# Environment
.env
.env.local
.env.*.local

# Keys and secrets (never commit these)
*.key
*.pem
secrets/
keys/private/
# Local backups of program upgrade-authority keypairs.
# Never publish these — anyone holding a copy can rewrite the program
# on mainnet (until --final).
/keys/

# Trusted setup artefacts (ephemeral, regenerated locally)
*.ptau
*.zkey
/setup/

# Build artefacts
/build/
/dist/

# Logs
*.log
logs/

# Anchor / Solana build outputs
.anchor/
target/deploy/*.json
!target/deploy/.gitkeep

# Claude Code session files (local scratch, never published)
.claude/
.DS_Store

# Video recordings (local, uploaded separately to YouTube/Loom)
/timeline/

# wasm-pack output — regenerated via `wasm-pack build` and published
# to the tidex6-web static dir, not checked in to the source tree.
crates/tidex6-prover-wasm/pkg/
